    "description": "REX module for domain list management (blocking, allowing, categorization) with IndexedDB storage.",
    "keywords": [
        "extension",
        "rex",
        "lists",
        "blocking",
        "filtering"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "homepage": "https://github.com/bric-digital/rex-lists",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-lists/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-lists.git"
    },
    "exports": {
        ".": "./src/list-utilities.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
